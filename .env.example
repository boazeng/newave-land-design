# ===========================================
# Newave Land Design - Local Environment Variables
# ===========================================
# Shared variables (AWS, AI keys) are loaded from ../Aiprojects/.env

# --- Backend ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api

# --- GovMap ---
GOVMAP_API_URL=https://ags.govmap.gov.il
GOVMAP_API_KEY=

# --- Database (PostgreSQL + PostGIS) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=newave_land
DB_USER=postgres
DB_PASSWORD=

# --- AWS (project-specific) ---
S3_BUCKET=
